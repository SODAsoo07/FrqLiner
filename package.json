{
  "name": "frqliner",
  "productName": "Frqliner",
  "version": "1.0.0",
  "description": "UTAU FRQ F0 curve editor",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build:win": "cross-env ELECTRON_BUILD=true npm run build && electron-builder --win",
    "electron:build:mac": "cross-env ELECTRON_BUILD=true npm run build && electron-builder --mac",
    "electron:build": "cross-env ELECTRON_BUILD=true npm run build && electron-builder --win --mac",
    "lint": "eslint .",
    "llsm:inspect": "node tools/inspect-llsm.cjs",
    "llsm:read": "node tools/llsm-tool.cjs pitch export",
    "llsm:write": "node tools/llsm-tool.cjs pitch apply",
    "llsm:pitch:shift": "node tools/llsm-tool.cjs pitch shift",
    "llsm:exp:header-set": "node tools/llsm-tool.cjs experimental header-set"
  },
  "build": {
    "appId": "com.frqliner.app",
    "productName": "Frqliner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko_KR",
        "en_US"
      ],
      "language": "1042"
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "meyda": "^5.6.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uhtml": "^5.0.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  }
}
